{% comment %}
  Mode Selection Popup — First-time visitor modal
  Shows fullscreen popup asking user to select shopping mode
{% endcomment %}

<div id="mode-popup" class="mode-popup" role="dialog" aria-modal="true" aria-label="Select shopping mode">
  <div class="mode-popup__overlay"></div>
  <div class="mode-popup__container">
    <div class="mode-popup__content">
      <h2 class="mode-popup__title">Who are you shopping for?</h2>
      <p class="mode-popup__subtitle">Choose your experience and we'll personalize the store for you.</p>

      <div class="mode-popup__options">
        {%- comment -%} Men Button {%- endcomment -%}
        <button
          type="button"
          class="mode-popup__btn mode-popup__btn--men"
          data-mode-value="men"
          aria-label="Shop for Men"
          onclick="ModeManager.applyMode('men', true); if(window.ProductFilter) ProductFilter.filter('men');"
        >
          <span class="mode-popup__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="14" r="8" stroke="currentColor" stroke-width="2.5" fill="none"/>
              <path d="M8 42c0-8.837 7.163-16 16-16s16 7.163 16 16" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="mode-popup__label">Men</span>
          <span class="mode-popup__desc">Bold & Modern</span>
        </button>

        {%- comment -%} Women Button {%- endcomment -%}
        <button
          type="button"
          class="mode-popup__btn mode-popup__btn--women"
          data-mode-value="women"
          aria-label="Shop for Women"
          onclick="ModeManager.applyMode('women', true); if(window.ProductFilter) ProductFilter.filter('women');"
        >
          <span class="mode-popup__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="16" r="10" stroke="currentColor" stroke-width="2.5" fill="none"/>
              <path d="M24 26v12M18 34h12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="mode-popup__label">Women</span>
          <span class="mode-popup__desc">Elegant & Refined</span>
        </button>

        {%- comment -%} Kids Button {%- endcomment -%}
        <button
          type="button"
          class="mode-popup__btn mode-popup__btn--kids"
          data-mode-value="kids"
          aria-label="Shop for Kids"
          onclick="ModeManager.applyMode('kids', true); if(window.ProductFilter) ProductFilter.filter('kids');"
        >
          <span class="mode-popup__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="24" cy="18" r="8" stroke="currentColor" stroke-width="2.5" fill="none"/>
              <path d="M14 42c0-5.523 4.477-10 10-10s10 4.477 10 10" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round"/>
              <path d="M16 12l-4-6M32 12l4-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
              <circle cx="20" cy="17" r="1.5" fill="currentColor"/>
              <circle cx="28" cy="17" r="1.5" fill="currentColor"/>
              <path d="M21 22c1.5 1.5 4.5 1.5 6 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="mode-popup__label">Kids</span>
          <span class="mode-popup__desc">Fun & Colorful</span>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .mode-popup {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 999999;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .mode-popup.active {
    display: flex;
  }

  .mode-popup__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .mode-popup__container {
    position: relative;
    z-index: 1;
    max-width: 700px;
    width: 90%;
    background: #ffffff;
    border-radius: 20px;
    padding: 48px 32px;
    text-align: center;
    animation: popupFadeIn 0.4s ease;
  }

  @keyframes popupFadeIn {
    from { opacity: 0; transform: scale(0.9) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .mode-popup__title {
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 8px;
  }

  .mode-popup__subtitle {
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 15px;
    color: #666;
    margin: 0 0 36px;
  }

  .mode-popup__options {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .mode-popup__btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 16px;
    border: 2px solid #e0e0e0;
    border-radius: 16px;
    background: #ffffff;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: 'Inter', -apple-system, sans-serif;
  }

  .mode-popup__btn:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
  }

  .mode-popup__btn--men {
    color: #0f3460;
  }

  .mode-popup__btn--men:hover {
    border-color: #0f3460;
    background: #f0f4fa;
  }

  .mode-popup__btn--women {
    color: #b76e79;
  }

  .mode-popup__btn--women:hover {
    border-color: #b76e79;
    background: #fdf6f0;
  }

  .mode-popup__btn--kids {
    color: #4D96FF;
  }

  .mode-popup__btn--kids:hover {
    border-color: #4D96FF;
    background: #f0f8ff;
    animation: kidBounce 0.4s ease;
  }

  .mode-popup__icon {
    display: block;
    margin-bottom: 12px;
  }

  .mode-popup__label {
    display: block;
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .mode-popup__desc {
    display: block;
    font-size: 12px;
    color: #999;
    font-weight: 400;
  }

  /* Mobile: stack vertically */
  @media screen and (max-width: 599px) {
    .mode-popup__container {
      padding: 32px 20px;
      width: 95%;
      max-height: 90vh;
      overflow-y: auto;
    }

    .mode-popup__options {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .mode-popup__btn {
      flex-direction: row;
      padding: 20px;
      gap: 16px;
      text-align: left;
    }

    .mode-popup__icon {
      margin-bottom: 0;
    }

    .mode-popup__title {
      font-size: 22px;
    }
  }
</style>
